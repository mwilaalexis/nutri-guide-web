# --- Dev (npm run dev) ---
# Leave VITE_API_BASE_URL unset. The app uses relative /api/* URLs and Vite proxies them.
# Dev gateway (HTTPS). Vite proxy uses secure: false for the self-signed dev cert.
# Prefer localhost, not 127.0.0.1:5284 — HTTP often redirects to https://127.0.0.1:7059 (cert mismatch).
VITE_GATEWAY_URL=https://localhost:7059

# Optional: route all /api/* only through the gateway (recommended).
VITE_GATEWAY_ONLY=true

# Only used when VITE_GATEWAY_ONLY is not true:
VITE_DEV_NOTIFICATIONS_ORIGIN=https://localhost:7072
VITE_DEV_TRACKING_ORIGIN=https://localhost:7073

# Optional: hero background video URL (landing page).
# VITE_HERO_VIDEO_URL=https://example.com/my-hero.mp4

# Do NOT set in dev (causes ERR_CERT_* if pointing at https://127.0.0.1:7059):
# VITE_API_BASE_URL=https://localhost:7059

# --- Production build ---
# VITE_API_BASE_URL=https://api.your-domain.com
