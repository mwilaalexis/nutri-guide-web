# Dev API: leave VITE_API_BASE_URL unset — browser uses http://localhost:5174 and Vite proxies below.
#
# Gateway (test.Server / Ocelot) — same as reactproject1/test/test.Server/Gateway.http
#   REST client:  http://127.0.0.1:5284   (@gateway in Gateway.http)
#   HTTPS profile: https://localhost:7059  (GlobalConfiguration.BaseUrl in ocelot.json)
#
# Use HTTPS for npm run dev (avoids redirect 5284 → 127.0.0.1:7059 + cert errors in browser):
VITE_GATEWAY_URL=https://localhost:7059
# If you only run the gateway HTTP profile, uncomment instead:
# VITE_GATEWAY_URL=http://127.0.0.1:5284

# Direct HTTPS microservices (dev). Vite forwards:
#   /api/notifications → VITE_DEV_NOTIFICATIONS_ORIGIN
#   /api/tracking      → VITE_DEV_TRACKING_ORIGIN
# Everything else under /api → VITE_GATEWAY_URL
# Recommandé : tout /api passe par Ocelot (profile + tracking + weight-entries).
VITE_GATEWAY_ONLY=true
VITE_DEV_NOTIFICATIONS_ORIGIN=https://localhost:7072
VITE_DEV_TRACKING_ORIGIN=https://localhost:7073

# Do NOT set this unless you trust the local HTTPS dev certificate in the browser:
# VITE_API_BASE_URL=https://localhost:7059
